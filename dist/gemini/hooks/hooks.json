{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "activate_skill",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/gemini_adapter.py BeforeTool",
            "name": "pretool-verify",
            "timeout": 60000,
            "description": "Adds context reminder before /verify"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "activate_skill|write_todos",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/gemini_adapter.py AfterTool",
            "name": "posttool-log",
            "timeout": 60000,
            "description": "Reminds agent to update execution log after milestone tool calls"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/gemini_adapter.py AfterAgent",
            "name": "stop-do-enforcement",
            "timeout": 60000,
            "description": "Blocks premature stops during /do workflow"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/gemini_adapter.py BeforeAgent",
            "name": "prompt-submit-amendment",
            "timeout": 60000,
            "description": "Checks for manifest amendments during /do and reinforces /understand principles"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/gemini_adapter.py SessionStart",
            "name": "post-compact-recovery",
            "timeout": 60000,
            "description": "Recovers /do and /understand context after compaction (source=resume)"
          }
        ]
      }
    ]
  }
}
